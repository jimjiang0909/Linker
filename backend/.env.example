# ===========================================
# Linker MVP 环境变量模板
# 复制此文件为 .env 并填入实际值
# ===========================================

# 应用配置
NODE_ENV=development
PORT=3000

# 数据库配置 (PostgreSQL)
# connection_limit: max connections in pool (default 5, recommended 10-20 for production)
# pool_timeout: seconds to wait for available connection (default 10)
DATABASE_URL=postgresql://linker:linker_secret@postgres:5432/linker_db?schema=public&connection_limit=20&pool_timeout=10

# JWT 认证
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_REFRESH_EXPIRES_IN=30d

# Resend 邮件服务
RESEND_API_KEY=re_xxxxxxxx
EMAIL_FROM=Linker <noreply@yourdomain.com>

# CloudFlare AI Gateway + OpenAI
OPENAI_API_KEY=sk-xxxxxxxx
CF_AIG_BASE_URL=https://gateway.ai.cloudflare.com/v1/4140c0dc09d603923bdce539c8c83714/jim/openai
CF_AIG_TOKEN=your_cf_aig_token_here

# WebSocket 配置
WS_CORS_ORIGIN=*

# 定时任务配置 (CST 时区)
TZ=Asia/Shanghai

# 文件上传配置
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# 推送通知 (Firebase Cloud Messaging - 可选)
# FCM_SERVER_KEY=your_fcm_server_key_here
# FCM_PROJECT_ID=your_firebase_project_id

# API 文档 (访问 /api-docs 查看 Swagger UI)
ENABLE_API_DOCS=true
